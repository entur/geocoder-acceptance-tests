    {
      "id": "kaia kafe",
      "endpoint": "autocomplete",
      "status": "pass",
      "in": {
        "q": "kaia kafe"
      },
      "expected": {
        "priorityThresh": 3,
        "properties": [
          {
            "address": {
              "county": "Nordland",
              "countyId": "KVE:TopographicPlace:18",
              "locality": "Narvik",
              "localityId": "KVE:TopographicPlace:1806"
            }
          }
        ]
      }
    },
