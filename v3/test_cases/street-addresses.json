{
  "name": "Street addresses",
  "description": "Verify presence of street addresses",
  "tests": [
    {
      "id": "karjohansgate",
      "endpoint": "autocomplete",
      "status": "pass",
      "in": {
        "q": "karl johans gate 2"
      },
      "expected": {
        "priorityThresh": 3,
        "properties": [
          {
            "categories": ["vegadresse"],
            "address": {
              "streetName": "Karl Johans gate",
              "houseNumber": "2"
            },
            "name": {
              "default": "Karl Johans gate 2",
              "display": "Karl Johans gate 2, Sarpsborg"
            }
          }
        ]
      }
    },
    {
      "id": "karjohansgate-nonumber",
      "endpoint": "autocomplete",
      "status": "pass",
      "in": {
        "q": "karl johans gate"
      },
      "expected": {
        "priorityThresh": 4,
        "properties": [
          {
            "categories": ["street"],
            "address": {
              "streetName": "Karl Johans gate"
            },
            "name": {
              "default": "Karl Johans gate",
              "display": "Karl Johans gate, Sarpsborg"
            }
          }
        ]
      }
    },
    {
      "id": "strandkaien",
      "endpoint": "autocomplete",
