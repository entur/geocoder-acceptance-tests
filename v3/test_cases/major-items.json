{
  "name": "Major items",
  "description": "Verify most important stop places in cities",
  "tests": [
    {
      "id": "oslo1",
      "endpoint": "autocomplete",
      "status": "pass",
      "in": {
        "q": "oslo"
      },
      "expected": {
        "priorityThresh": 4,
        "properties": [
          {
            "id": "NSR:GroupOfStopPlaces:1"
          }
        ]
      }
    },
    {
      "id": "oslo s",
      "endpoint": "autocomplete",
      "status": "pass",
      "in": {
        "q": "oslo s",
        "limit": 30
      },
      "expected": {
        "priorityThresh": 2,
        "properties": [
          {
            "id": "NSR:GroupOfStopPlaces:1"
          }
        ]
      },
      "unexpected": {
        "priorityThresh": 30,
        "properties": [
          {
            "name": {
              "default": "Lio's Cafe Bar"
            }
          },
          {
            "name": {
              "default": "Tiffany’s"
            }
          },
          {
            "name": {
              "default": "Stockfleth's"
            }
          }
        ]
      }
    },
